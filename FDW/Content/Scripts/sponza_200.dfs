# Sponza mixed lights stress scene (~200 lights).
# Legacy behavior rewritten with arrays + loops.

seed = 0.427;

function NextRand() {
    seed = seed * 1.6180339 + 0.2113249;
    while (seed > 1) {
        seed = seed - 1;
    }
    return seed;
}

function RandRange(minV, maxV) {
    return minV + (maxV - minV) * NextRand();
}

function LightName(i) {
    n = "MegaLight";
    if (i < 10) { n = n + "00"; }
    if (i > 9) {
        if (i < 100) { n = n + "0"; }
    }
    return n + i;
}

cam = world.GetEntityByName("ScriptCamera200");
if (cam == 0) {
    cam = world.CreateDefaultCamera();
    world.SetEntityName(cam, "ScriptCamera200");
    world.SetDefaultCameraEye(cam, 0, 210, 0 - 1);
    world.SetCameraSpeed(cam, 260);
}

scene = world.GetEntityByName("ScriptSponza");
if (scene == 0) {
    scene = world.CreateScene("Content/SampleModels/sponza/scene.gltf");
    world.SetEntityName(scene, "ScriptSponza");
}

