inten[200] = 200.104; idir[200] = 1.000; heat[200] = 55.397;
radius[200] = 160.139;
colR[200] = 0.226; colG[200] = 0.862; colB[200] = 0.226;
coneIn[200] = 0.000; coneOut[200] = 0.000;
dirX[200] = 0.000; dirY[200] = 0.000; dirZ[200] = 0.000;
rectW[200] = 31.964; rectH[200] = 14.394;
rectY[200] = 0 - 2.759; rectTargetY[200] = 1.135;
distLim[200] = 725.819; yMinLim[200] = 65.655; yMaxLim[200] = 261.273;
dirLerp[200] = 0.000; rotLerp[200] = 1.076;

# Override placement/brightness ranges:
# radius in [300..800], and larger radius -> lower intensity.
i = 1;
while (i <= 200) {
    x[i] = RandRange(0 - 800, 800);
    y[i] = RandRange(220, 1200);
    z[i] = RandRange(0 - 800, 800);

    tx[i] = RandRange(0 - 800, 800);
    ty[i] = RandRange(220, 1200);
    tz[i] = RandRange(0 - 800, 800);

    yMinLim[i] = 220;
    yMaxLim[i] = 1200;
    distLim[i] = RandRange(3500, 9000);
    spd[i] = RandRange(0.07, 0.24);

    radius[i] = RandRange(300, 800);
    radiusT = (radius[i] - 300) / 500;
    intenScale = 1.10 - radiusT * 0.50;
    if (imin[i] < 95) { imin[i] = 95; }
    if (imax[i] < 180) { imax[i] = 180; }
    imin[i] = imin[i] * intenScale;
    imax[i] = imax[i] * intenScale;
    if (imin[i] < 55) { imin[i] = 55; }
    if (imin[i] > imax[i] - 25) { imin[i] = imax[i] - 25; }
    inten[i] = RandRange(imin[i], imax[i]);
    idir[i] = 1;
    if (heat[i] < 18) { heat[i] = 18; }

    if (kind[i] == 1) {
        if (coneOut[i] < 0.70) { coneOut[i] = 0.70; }
        if (coneIn[i] < 0.30) { coneIn[i] = 0.30; }
        if (coneIn[i] > coneOut[i] - 0.10) { coneIn[i] = coneOut[i] - 0.10; }
        dirX[i] = RandRange(0 - 0.9, 0.9);
        dirY[i] = RandRange(0 - 1.0, 0 - 0.2);
        dirZ[i] = RandRange(0 - 0.9, 0.9);
        if (dirLerp[i] < 0.8) { dirLerp[i] = 0.8; }
    }

    i = i + 1;
}

i = 1;
while (i <= 200) {
    name = LightName(i);
    l = world.GetEntityByName(name);

    if (l != 0) {
        world.DestroyEntity(l);
        l = 0;
    }

    if (kind[i] == 0) { l = world.CreatePointLight(); }
    if (kind[i] == 1) { l = world.CreateSpotLight(); }
    world.SetEntityName(l, name);

    lights[i] = l;

    world.SetLightPosition(l, x[i], y[i], z[i]);
    world.SetLightAttenuationRadius(l, radius[i]);
    world.SetLightIntensity(l, inten[i]);
    world.SetLightColor(l, colR[i], colG[i], colB[i]);

    if (kind[i] == 1) {
        world.SetLightConeAngles(l, coneIn[i], coneOut[i]);
        world.SetLightDirection(l, dirX[i], dirY[i], dirZ[i]);
    }

    i = i + 1;
}

loop 1 {
    dt = GetDeltaTime();

    if (scriptUpdateBatch < 1) { scriptUpdateBatch = 1; }
    if (scriptUpdateStart < 1) { scriptUpdateStart = 1; }
    if (scriptUpdateStart > 200) { scriptUpdateStart = 1; }

    scriptUpdateEnd = scriptUpdateStart + scriptUpdateBatch - 1;
    if (scriptUpdateEnd > 200) { scriptUpdateEnd = 200; }

    world.UpdateScriptLightsNative(
        lights, kind, x, y, z, tx, ty, tz, spd, distLim, yMinLim, yMaxLim,
        inten, idir, heat, imin, imax, dirX, dirY, dirZ, dirLerp,
        dt, scriptUpdateStart, scriptUpdateEnd
    );

    scriptUpdateStart = scriptUpdateEnd + 1;
    if (scriptUpdateStart > 200) { scriptUpdateStart = 1; }
}
